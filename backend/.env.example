# FreeTheAI API Configuration
FREETHEAI_API_KEY=your_api_key_here
# Get your API key at: https://discord.gg/secrets
# Steps:
# 1. Join the Discord server
# 2. Run /signup command
# 3. Copy your API key and paste it above

# Model Configuration
LLM_MODEL=gemini-2.5-flash-lite

# Server Configuration
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKSPACE_PATH=./workspace

# Database Configuration (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Security
API_KEY_SECRET=change-this-to-a-random-string-in-production

# Agent Configuration
MAX_ITERATIONS=10
TIMEOUT_SECONDS=300
